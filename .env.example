# ========================================
# LLM生成模型配置
# ========================================
# LLM服务的基础URL，支持OpenAI兼容的API接口
# 常见值：
#   - https://api.openai.com/v1 (OpenAI官方)
#   - https://api.deepseek.com (DeepSeek)
#   - 其他兼容OpenAI API格式的服务地址
LLM_BASE_URL=https://api.openai.com/v1

# LLM服务的API密钥（必填）
# 获取方式：访问对应服务平台的开发者后台
LLM_API_KEY=your_llm_api_key

# 用于对话和内容生成的模型名称
# 常见值：gpt-4o, gpt-4-turbo, gpt-3.5-turbo, deepseek-chat等
CHAT_MODEL=gpt-4o

# 用于数据清洗和简单任务的模型名称（通常使用更经济的模型）
# 常见值：gpt-4o-mini, gpt-3.5-turbo等
CLEAN_MODEL=gpt-4o-mini

# ========================================
# Embedding模型配置
# ========================================
# Embedding服务的基础URL
# 通常与LLM使用同一服务，但也可是独立的Embedding服务
EMBEDDING_BASE_URL=https://api.openai.com/v1

# Embedding服务的API密钥（可选）
# 如果与LLM使用同一服务且API密钥相同，可留空
# 如使用不同服务，请填写对应的API密钥
EMBEDDING_API_KEY=

# 用于文本向量化的模型名称
# 常见值：text-embedding-3-small, text-embedding-3-large, text-embedding-ada-002等
EMBEDDING_MODEL=text-embedding-3-small

# ========================================
# 定时任务时间配置
# ========================================
# 开盘前报告生成时间（24小时制，格式：HH:MM）
# 建议设置在股市开盘前30分钟左右
PRE_MARKET_TIME=08:30

# 中午收盘报告生成时间（24小时制，格式：HH:MM）
# A股中午收盘时间为11:30
MID_CLOSE_TIME=11:30

# 晚间收盘报告生成时间（24小时制，格式：HH:MM）
# A股收盘时间为15:00，建议设置在15:30左右
AFTER_CLOSE_TIME=15:30

# ========================================
# 日志配置
# ========================================
# 日志级别，控制日志输出的详细程度
# 可选值：
#   - DEBUG: 最详细，包含调试信息
#   - INFO: 一般信息（推荐用于日常使用）
#   - WARNING: 仅警告和错误
#   - ERROR: 仅错误信息
LOG_LEVEL=INFO
